{# avatar — circular initials block.
   Args:
     - initials: 1-3 letters
     - size:     '' (24px) | 'md' (32px) | 'lg' (48px)
     - colour:   '' (neutral) | 'purple' | 'orange' | 'green' | 'red' | 'teal' | 'pink'
#}
{% macro avatar(initials, size="", colour="") %}
{%- set classes = ['avatar'] -%}
{%- if size %}{% set classes = classes + ['avatar-' ~ size] %}{% endif -%}
{%- if colour %}{% set classes = classes + ['avatar-' ~ colour] %}{% endif -%}
<span class="{{ classes|join(' ') }}" aria-hidden="true">{{ initials }}</span>
{% endmacro %}
