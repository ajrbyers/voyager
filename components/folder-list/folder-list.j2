{# folder-list — inbox-style sidebar.

   Compose with three macros:
     - folder_list(search_action="", search_value="")   wrapper
     - folder_list_section(label)                       section header
     - folder_item(label, url, icon, count, current,
                   severity, custom, dot_color, edit_url, delete_url)

   Usage:
     {% call folder_list(search_action="/inbox/search") %}
       {% call folder_list_section("Workflow") %}
         {{ folder_item("Unassigned",  url="?folder=unassigned",
                        icon="✉", count=7, severity="warning") }}
         {{ folder_item("Peer Review", url="?folder=peer_review",
                        icon="⌕", count=14, severity="critical", current=True) }}
       {% endcall %}
     {% endcall %}
#}

{% macro folder_list(search_action="", search_value="", label="Inbox folders") %}
<nav class="folder-list" aria-label="{{ label }}">
  {% if search_action %}
  <div class="folder-list-search">
    <label class="visually-hidden" for="inbox-search">Search articles</label>
    <input type="search" id="inbox-search" name="q" class="form-input"
           placeholder="Search articles…" autocomplete="off"
           value="{{ search_value }}">
  </div>
  {% endif %}
  <div class="folder-list-scroll">
    <ul>{{ caller() }}</ul>
  </div>
</nav>
{% endmacro %}

{% macro folder_list_section(label, first=False) %}
<li><h2 class="folder-list-section{% if first %} folder-list-section-first{% endif %}">{{ label }}</h2></li>
{% endmacro %}

{% macro folder_item(label, url="#", icon=None, count=None, current=False,
                      severity=None, custom=False, dot_color=None,
                      edit_url=None, delete_url=None) %}
{% if custom %}
<li class="folder-item folder-item-custom{% if current %} is-active{% endif %}">
  <a href="{{ url }}" class="folder-item-link">
    {% if dot_color %}<span class="folder-item-dot"></span>{% endif %}
    <span class="folder-item-name">{{ label }}</span>
    {% if count is not none %}
      <span class="folder-item-count{% if severity %} folder-item-count-{{ severity }}{% endif %}">{{ count }}</span>
    {% endif %}
  </a>
  {% if edit_url or delete_url %}
  <div class="folder-item-actions">
    {% if edit_url %}<button type="button" class="folder-item-action-btn" aria-label="Edit folder">✎</button>{% endif %}
    {% if delete_url %}<button type="button" class="folder-item-action-btn folder-item-action-btn-danger" aria-label="Delete folder">×</button>{% endif %}
  </div>
  {% endif %}
</li>
{% else %}
<li>
  <a href="{{ url }}" class="folder-item{% if current %} is-active{% endif %}"
     {% if current %}aria-current="page"{% endif %}>
    {% if icon %}<span class="folder-item-icon" aria-hidden="true">{{ icon }}</span>{% endif %}
    <span class="folder-item-name">{{ label }}</span>
    {% if count is not none %}
      <span class="folder-item-count{% if severity %} folder-item-count-{{ severity }}{% endif %}">{{ count }}</span>
    {% endif %}
  </a>
</li>
{% endif %}
{% endmacro %}

{% macro folder_list_add(label="New folder", url="#") %}
<button type="button" class="folder-list-add">+ {{ label }}</button>
{% endmacro %}
