{% macro icon(name, title=None, size=None, class="") %}
{%- set size_class = ('icon-' ~ size) if size and size in ['sm','md','lg','xl'] else '' -%}
{%- set custom_size = size if size and size not in ['sm','md','lg','xl'] else None -%}
<svg class="icon{% if size_class %} {{ size_class }}{% endif %}{% if class %} {{ class }}{% endif %}"
     {% if custom_size %}width="{{ custom_size }}" height="{{ custom_size }}"{% endif %}
     viewBox="0 0 24 24"
     {% if title %}role="img" aria-label="{{ title }}"{% else %}aria-hidden="true"{% endif %}>
  {% if title %}<title>{{ title }}</title>{% endif %}
  {{ _ICONS[name]|safe }}
</svg>
{% endmacro %}
